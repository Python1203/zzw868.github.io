-            strategy: [
-              '策略方面，最重要的是坚持执行，不要频繁更换。💪',
-              '好的策略需要时间验证，不要急于求成。📚'
-            ],
-            risk: [
-              '风险控制是第一位的，宁可错过，不要做错。🛡️',
-              '留得青山在，不怕没柴烧。保护本金最重要。💰'
-            ]
-          };
-          
-          if (contextualResponses[lastTopic]) {
-            return randomSelect(contextualResponses[lastTopic]);
-          }
-          return randomSelect(aiResponses.default);
-        };
-
-        // 随机选择
-        const randomSelect = (arr) => {
-          return arr[Math.floor(Math.random() * arr.length)];
-        };
-
-        // 滚动到底部
-        const scrollToBottom = () => {
-          const container = document.querySelector('.chat-messages');
-          if (container) {
-            container.scrollTop = container.scrollHeight;
-          }
-        };
-
-        // 监听消息变化自动滚动
-        watch(messages, () => {
-          nextTick(() => scrollToBottom());
-        });
-
-        return {
-          isChatOpen,
-          userInput,
-          messages,
-          isTyping,
-          showQuickReplies,
-          quickReplies,
-          toggleChat,
-          sendMessage,
-          sendQuickReply
-        };
-      }
-    }).mount('#aiChatWidget');
-  </script>
