-// 计算简单移动平均线
-function calculateMA(dayCount, data) {
-  const result = [];
-  for (let i = 0; i < data.length; i++) {
-    if (i < dayCount - 1) {
-      result.push('-');
-      continue;
-    }
-    let sum = 0;
-    for (let j = 0; j < dayCount; j++) {
-      sum += data[i - j][1]; // close price
-    }
-    result.push((sum / dayCount).toFixed(2));
-  }
-  return result;
-}
