-        // ==================== AI 优化系统 ====================
-        function collectFeedback(messageHash, rating, feedback = '') {
-            if (!aiOptimizationData.responseQuality[messageHash]) {
-                aiOptimizationData.responseQuality[messageHash] = {
-                    quality: 0.5,
-                    feedbackCount: 0,
-                    ratings: [],
-                    feedbacks: []
-                };
-            }
-
-            const record = aiOptimizationData.responseQuality[messageHash];
-            record.ratings.push(rating);
-            record.feedbackCount++;
-
-            const sum = record.ratings.reduce((a, b) => a + b, 0);
-            record.avgRating = (sum / record.ratings.length) / 3;
-
-            if (feedback) {
-                record.feedbacks.push(feedback);
-            }
-
-            aiOptimizationData.totalInteractions++;
-            if (rating >= 2) {
-                aiOptimizationData.successfulResponses++;
-            }
-
-            console.log(`📊 反馈已记录 - 质量评分：${record.avgRating.toFixed(2)}`);
-            updateOptimizationPanel();
-        }
