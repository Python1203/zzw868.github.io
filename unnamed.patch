-            updateContext('market', market);
-            return randomSelect(aiResponses.market_analysis)
-              .replace('{{trend}}', trend)
-              .replace('{{market}}', market);
-          }
-
-          // 7. 技术分析
-          if (aiKnowledgeBase.analysis.some(k => lowerText.includes(k)) && 
-              (lowerText.includes('技术') || lowerText.includes('指标'))) {
-            updateContext('technical', null);
-            return randomSelect(aiResponses.technical_analysis);
-          }
-
-          // 8. 交易建议
-          if (aiKnowledgeBase.trading.some(k => lowerText.includes(k)) || 
