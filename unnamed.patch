-  // 计算累积量
-  function accumulate(data) {
-    let sum = 0;
-    return data.map(([price, volume]) => {
-      sum += volume;
-      return [price, sum];
-    });
-  }
-
-  const bidData = accumulate(bids.slice().reverse());
-  const askData = accumulate(asks);
