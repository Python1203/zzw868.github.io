-            updateContext('trading', specificMarket);
-            return randomSelect(aiResponses.trading_advice);
-          }
-
-          // 9. 策略咨询
-          if (aiKnowledgeBase.strategy.some(k => lowerText.includes(k))) {
-            updateContext('strategy', null);
-            return randomSelect(aiResponses.strategy_suggestion);
-          }
-
-          // 10. 风险询问
-          if (aiKnowledgeBase.risk.some(k => lowerText.includes(k))) {
-            updateContext('risk', null);
-            return randomSelect(aiResponses.risk_warning);
-          }
-
-          // 11. 上下文关联回复
-          if (conversationContext.lastTopic) {
-            return generateContextualResponse(conversationContext.lastTopic);
-          }
-
-          // 12. 默认回复
-          updateContext('unknown', null);
-          return randomSelect(aiResponses.default);
-        };
-        
-        // 情感分析
-        const analyzeSentiment = (text) => {
-          const positiveWords = ['涨', '涨', '赚钱', '利好', '机会', '看好', '买入'];
-          const negativeWords = ['跌', '跌', '亏损', '利空', '风险', '看空', '卖出'];
-          
-          let score = 0;
-          positiveWords.forEach(word => {
-            if (text.includes(word)) score++;
-          });
-          negativeWords.forEach(word => {
-            if (text.includes(word)) score--;
-          });
-          
-          if (score > 0) {
-            conversationContext.userSentiment = 'positive';
-          } else if (score < 0) {
-            conversationContext.userSentiment = 'negative';
-          } else {
-            conversationContext.userSentiment = 'neutral';
-          }
-        };
-        
-        // 更新上下文
-        const updateContext = (topic, market) => {
-          conversationContext.lastTopic = topic;
-          if (market) {
-            conversationContext.lastMarket = market;
-          }
-        };
-        
-        // 生成上下文关联回复
-        const generateContextualResponse = (lastTopic) => {
-          const contextualResponses = {
-            market: [
-              '继续刚才的话题，从更长期来看，市场趋势仍然向好。📈',
-              '补充一下，除了技术面，基本面也很重要。💡'
-            ],
-            trading: [
-              '关于交易，我再多说一句：仓位管理比选股更重要。🎯',
-              '记住：不要追涨杀跌，耐心等待机会。⏰'
