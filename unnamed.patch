-            document.getElementById('aiLevel').textContent = `Lv.${data.optimizationLevel}`;
-            document.getElementById('totalInteractions').textContent = data.totalInteractions;
-
-            const successRate = data.totalInteractions > 0
-                ? ((data.successfulResponses / data.totalInteractions) * 100).toFixed(1)
-                : 0;
-            document.getElementById('successRate').textContent = `${successRate}%`;
-
-            const totalFeedback = Object.values(data.responseQuality)
-                .reduce((sum, record) => sum + record.feedbackCount, 0);
-            document.getElementById('feedbackCount').textContent = totalFeedback;
-
-            const progress = (data.optimizationLevel / 10) * 100;
-            document.getElementById('progressBar').style.width = `${progress}%`;
-            document.getElementById('progressText').textContent = `${progress.toFixed(0)}%`;
-        }
