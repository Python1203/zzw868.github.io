-          // 5. 以太坊专项分析
-          if (specificMarket === 'ETH' || aiKnowledgeBase.eth.some(k => lowerText.includes(k))) {
-            updateContext('eth', 'ETH');
-            return randomSelect(aiResponses.eth_analysis);
-          }
-
-          // 6. 市场行情相关
-          if (aiKnowledgeBase.market.some(k => lowerText.includes(k)) || 
-              aiKnowledgeBase.analysis.some(k => lowerText.includes(k))) {
-            const trends = ['震荡上行', '高位整理', '小幅回调', '强势上涨', '盘整蓄势'];
-            const trend = randomSelect(trends);
