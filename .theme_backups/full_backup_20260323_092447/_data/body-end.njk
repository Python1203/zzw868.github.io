{# 财经文章结构化数据 - AI 友好型 #}
{% if is_post and page.categories and page.categories.length > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ page.permalink }}"
  },
  "headline": "{{ page.title }}",
  "description": "AI 生成的全球财经日报，深度分析美股、A 股、大宗商品及加密货币市场动态",
  "image": {
    "@type": "ImageObject",
    "url": "https://zzw868.github.io/images/logo.svg",
    "width": 800,
    "height": 600
  },
  "datePublished": "{{ page.date.toISOString() }}",
  "author": {
    "@type": "Person",
    "name": "666",
    "url": "https://zzw868.github.io"
  },
  "publisher": {
    "@type": "Organization",
    "name": "张良信息咨询服务工作室",
    "logo": {
      "@type": "ImageObject",
      "url": "https://zzw868.github.io/images/logo.svg"
    }
  },
  "articleSection": "财经",
  "citation": [
    {
      "@type": "CreativeWork",
      "name": "Yahoo Finance 行情数据",
      "url": "https://finance.yahoo.com/"
    },
    {
      "@type": "CreativeWork",
      "name": "AkShare 金融数据",
      "url": "https://akshare.akfamily.xyz/"
    },
    {
      "@type": "CreativeWork",
      "name": "Binance 加密货币数据",
      "url": "https://www.binance.com/"
    }
  ],
  "license": "CC-BY-NC-SA-4.0"
}
</script>
{% endif %}

