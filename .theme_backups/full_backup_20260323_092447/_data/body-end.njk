{# ── live2d 看板娘初始化 ────────────────────────────────────────────────────── #}
{# hexo-helper-live2d 会自动注入，此文件作为备用手动初始化方案 #}

{% if theme.live2d and theme.live2d.enable %}
<script>
  // live2d 由 hexo-helper-live2d 插件自动处理
  // 如需手动调整位置，修改下方参数
  if (window.loadlive2d) {
    loadlive2d("live2d", "/live2d-widget/assets/hibiki/model.json", {
      width: 150,
      height: 200,
      bottom: "0px",
      right: "0px",
      opacity: 0.9
    });
  }
</script>
{% endif %}

