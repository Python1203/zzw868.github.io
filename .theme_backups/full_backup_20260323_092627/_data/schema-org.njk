{# BlogPosting 结构化数据 - 用于财经文章 #}
{% if page and page.date %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ url_for(page.path) }}"
  },
  "headline": "{{ page.title }}",
  "description": "{{ page.description or 'AI 生成的全球财经日报，深度分析美股、A 股、大宗商品及加密货币市场动态。' }}",
  "image": {
    "@type": "ImageObject",
    "url": "https://zzw868.github.io/images/logo.svg",
    "width": 800,
    "height": 600
  },
