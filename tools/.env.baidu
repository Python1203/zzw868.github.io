# 环境变量设置方法：

# 方法 1: 临时设置（当前终端有效）
export AI_API_KEY='bce-v3/ALTAK-xNWWCIP6mLrKFV2KopRYy/a91d82e00aa2894b60900978be66a57d54d11099'
export AI_BASE_URL='https://qianfan.baidubce.com/v2'
export AI_SECRET_KEY='a91d82e00aa2894b60900978be66a57d54d11099'

# 方法 2: 永久设置（添加到 ~/.zshrc 或 ~/.bashrc）
echo 'export AI_API_KEY="bce-v3/ALTAK-xNWWCIP6mLrKFV2KopRYy/a91d82e00aa2894b60900978be66a57d54d11099"' >> ~/.zshrc
echo 'export AI_BASE_URL="https://qianfan.baidubce.com/v2"' >> ~/.zshrc
echo 'export AI_SECRET_KEY="a91d82e00aa2894b60900978be66a57d54d11099"' >> ~/.zshrc
source ~/.zshrc

# 方法 3: 使用脚本
# cd tools && ./run_baidu_ai.sh

